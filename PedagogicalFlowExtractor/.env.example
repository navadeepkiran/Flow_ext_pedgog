# ═══════════════════════════════════════════════════════════════
#  ENVIRONMENT VARIABLES TEMPLATE — Pedagogical Knowledge Graph Extractor
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED: API Keys ────────────────────────────────────────
# Groq API (Required for LLM features) - Get free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── OPTIONAL: Additional API Keys ─────────────────────────────
# OpenAI API (if you want to test GPT models instead of Groq)
OPENAI_API_KEY=

# ngrok Auth Token (for Colab tunnels longer than 2 hours)
# Get from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=

# ── MODEL CONFIGURATION ───────────────────────────────────────
# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=small

# Whisper language: null (auto-detect), en, hi, te
WHISPER_LANGUAGE=null

# LLM model for Groq
LLM_MODEL=llama-3.3-70b-versatile

# Maximum tokens for LLM responses
MAX_TOKENS=8192

# ── PIPELINE SETTINGS ─────────────────────────────────────────
# Graph builder settings
SIMILARITY_THRESHOLD=0.82
CHUNK_OVERLAP=0.2
ENABLE_COMMUNITIES=true

# Concept extraction mode: rule_based, llm, hybrid
DEFAULT_EXTRACTION_MODE=rule_based

# ── FILE PATHS ────────────────────────────────────────────────
OUTPUT_DIR=outputs
CS_CONCEPTS_PATH=data/cs_concepts.json
HINGLISH_LEXICON_PATH=data/hinglish_lexicon.json
TELUGU_LEXICON_PATH=data/telugu_english_lexicon.json

# ── DEVELOPMENT SETTINGS ──────────────────────────────────────
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode (verbose output)
DEBUG_MODE=false

# Streamlit configuration
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0

# ── SECURITY SETTINGS ─────────────────────────────────────────
# Disable CORS for Streamlit (Colab compatibility)
STREAMLIT_ENABLE_CORS=false

# Disable XSRF protection (Colab compatibility)  
STREAMLIT_ENABLE_XSRF=false

# ═══════════════════════════════════════════════════════════════
#  SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env (remove .example extension)
# 2. Update GROQ_API_KEY with your actual key from https://console.groq.com/keys  
# 3. Optionally update other settings
# 4. Never commit .env to version control (already in .gitignore)
#
# ═══════════════════════════════════════════════════════════════